system:
    instructions: "You are an AI Agent that helps users create Opportunities in Salesforce."
    messages:
        welcome: |
            Hi! I can help you create Opportunities. What would you like to do?
        error: "Sorry, something went wrong. Please try again."

config:
    developer_name: "Demo_Manage_Opportunities_Agent"
    agent_label: "Demo Manage Opportunities (Local)"
    agent_type: "AgentforceEmployeeAgent"
    description: "Agent for Opportunity creation with Account resolution - Local Demo Version"

language:
    default_locale: "en_US"

variables:
    opp_fields_json: mutable object = {}
        description: "Field metadata from GetOpportunityFieldsAction"
    opp_name: mutable string = ""
        description: "Opportunity Name"
    close_date: mutable string = ""
        description: "Close Date in YYYY-MM-DD format"
    stage_name: mutable string = ""
        description: "Opportunity Stage"
    account_input: mutable string = ""
        description: "User input for Account (ID or name)"
    account_id: mutable string = ""
        description: "Resolved Account ID"
    account_name: mutable string = ""
        description: "Resolved Account Name"
    account_match_count: mutable number = 0
        description: "Number of account matches found"
    account_options_json: mutable string = ""
        description: "JSON array of account disambiguation options"
    awaiting_account_selection: mutable boolean = False
        description: "Whether user needs to select from multiple accounts"
    created_oppty_id: mutable string = ""
        description: "ID of created Opportunity"
    create_oppty_error: mutable string = ""
        description: "Error from create action"
    last_error: mutable string = ""
        description: "Last validation or action error"
    user_confirm_create: mutable boolean = False
        description: "User confirmation to create"

start_agent agent_router:
    label: "Opportunity Router"
    description: "Route user requests to create opportunities"
    reasoning:
        instructions: ->
            | If the user wants to create an Opportunity, use {!@actions.go_to_create}.
        actions:
            go_to_create: @utils.transition to @subagent.create_opportunity
                description: "User wants to create a new Opportunity"

subagent create_opportunity:
    label: "Create Opportunity"
    description: "Guide user through creating an Opportunity with Account resolution"

    reasoning:
        instructions: ->
            # Always fetch field metadata first
            run @actions.Get_Opportunity_Fields
                with configurationName="Default"
                set @variables.opp_fields_json = @outputs.fieldsJson

            # Reset error each turn
            set @variables.last_error = ""

            # Guard: If already created, show success and stop
            if @variables.created_oppty_id != "":
                | Opportunity created successfully! ID: {!@variables.created_oppty_id}
                | View it at: /lightning/r/Opportunity/{!@variables.created_oppty_id}/view

            # If user provided account_input and we haven't resolved it yet
            if @variables.account_input != "" and @variables.account_id == "" and @variables.awaiting_account_selection == False:
                run @actions.Resolve_Account
                    with accountInput=@variables.account_input
                    set @variables.account_match_count = @outputs.matchCount

                # Single match found
                if @variables.account_match_count == 1:
                    set @variables.account_id = @outputs.accountId
                    set @variables.account_name = @outputs.accountName
                    | Using Account: {!@variables.account_name} ({!@variables.account_id})

                # Multiple matches - need disambiguation
                if @variables.account_match_count > 1:
                    set @variables.account_options_json = @outputs.disambiguationOptionsJson
                    set @variables.awaiting_account_selection = True
                    | I found {!@variables.account_match_count} accounts matching "{!@variables.account_input}".
                    | Please tell me which one by name or provide the exact Account ID.

                # No matches
                if @variables.account_match_count == 0:
                    set @variables.last_error = @outputs.errorMessage
                    | {!@variables.last_error}
                    | Please provide a valid Account ID (15/18 characters) or Account Name.

            # Guard: Required fields validation
            if @variables.created_oppty_id == "" and (@variables.opp_name == "" or @variables.close_date == "" or @variables.stage_name == "" or @variables.account_id == ""):
                set @variables.last_error = "Missing required fields: Name, Close Date (YYYY-MM-DD), Stage, and Account."
                | Please provide: Opportunity Name, Close Date (YYYY-MM-DD), Stage, and Account (ID or name).

            # Guard: Close date format validation
            if @variables.created_oppty_id == "" and @variables.last_error == "" and @variables.close_date != "" and (@variables.close_date[4] != "-" or @variables.close_date[7] != "-"):
                set @variables.last_error = "Close Date must be in YYYY-MM-DD format."
                | Error: {!@variables.last_error}

            # Guard: Ready to create - ask for confirmation
            if @variables.created_oppty_id == "" and @variables.last_error == "" and @variables.user_confirm_create == False and @variables.account_id != "":
                | Ready to create Opportunity:
                | Name: {!@variables.opp_name}
                | Close Date: {!@variables.close_date}
                | Stage: {!@variables.stage_name}
                | Account: {!@variables.account_name} ({!@variables.account_id})
                |
                | Confirm to create?

            # Guard: Create the opportunity
            if @variables.created_oppty_id == "" and @variables.last_error == "" and @variables.user_confirm_create == True and @variables.account_id != "":
                run @actions.Create_Opportunity
                    with configurationName="Default"
                    with fieldValuesJson="{\"Name\":\"" + @variables.opp_name + "\",\"CloseDate\":\"" + @variables.close_date + "\",\"StageName\":\"" + @variables.stage_name + "\",\"AccountId\":\"" + @variables.account_id + "\"}"
                    set @variables.created_oppty_id = @outputs.recordId
                    set @variables.create_oppty_error = @outputs.errorMessage

            # Handle create errors
            if @variables.create_oppty_error != "" and @variables.created_oppty_id == "":
                set @variables.last_error = @variables.create_oppty_error
                set @variables.user_confirm_create = False
                | Error creating Opportunity: {!@variables.last_error}
                | Please try again.

        actions:
            set_vars: @utils.setVariables
                description: "Set field values and confirmation"
                with opp_name=...
                with close_date=...
                with stage_name=...
                with account_input=...
                with user_confirm_create=...

    actions:
        Get_Opportunity_Fields:
            description: "Returns available Opportunity fields"
            label: "Get Opportunity Fields"
            target: "apex://GetOpportunityFieldsActionLocal"

            inputs:
                "configurationName": string
                    description: "Configuration name"
                    label: "Configuration Name"

            outputs:
                "fieldsJson": string
                    description: "Field metadata JSON"
                    label: "Fields JSON"
                "isSuccess": boolean
                    description: "Success flag"
                    label: "Success"
                "errorMessage": string
                    description: "Error message"
                    label: "Error Message"

        Resolve_Account:
            description: "Resolves Account from ID or name with disambiguation"
            label: "Resolve Account"
            target: "apex://ResolveAccountAction"

            inputs:
                "accountInput": string
                    description: "Account ID or name"
                    label: "Account Input"

            outputs:
                "accountId": string
                    description: "Resolved Account ID"
                    label: "Account Id"
                "accountName": string
                    description: "Resolved Account Name"
                    label: "Account Name"
                "matchCount": number
                    description: "Number of matches"
                    label: "Match Count"
                "disambiguationOptionsJson": string
                    description: "JSON array of options"
                    label: "Disambiguation Options"
                "isSuccess": boolean
                    description: "Success flag"
                    label: "Success"
                "errorMessage": string
                    description: "Error message"
                    label: "Error Message"

        Create_Opportunity:
            description: "Creates an Opportunity record"
            label: "Create Opportunity"
            target: "apex://CreateCustomObjectActionLocal"

            inputs:
                "configurationName": string
                    description: "Configuration name"
                    label: "Configuration Name"
                "fieldValuesJson": string
                    description: "JSON with field values"
                    label: "Field Values JSON"

            outputs:
                "recordId": string
                    description: "Created record ID"
                    label: "Record ID"
                "errorMessage": string
                    description: "Error message"
                    label: "Error Message"
                "isSuccess": boolean
                    description: "Success flag"
                    label: "Success"
