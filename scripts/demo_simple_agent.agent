system:
    instructions: "You are an AI Agent that helps users create Opportunities in Salesforce."
    messages:
        welcome: |
            Hi! I can help you create Opportunities. What would you like to do?
        error: "Sorry, something went wrong. Please try again."

config:
    developer_name: "Demo_Simple_Opportunities_Agent"
    agent_label: "Demo Simple Opportunities"
    agent_type: "AgentforceEmployeeAgent"
    description: "Simple agent for testing Opportunity creation"

language:
    default_locale: "en_US"

variables:
    opp_name: mutable string = ""
    close_date: mutable string = ""
    stage_name: mutable string = ""
    account_id: mutable string = ""
    created_oppty_id: mutable string = ""

start_agent collect_and_create:
    label: "Collect and Create Opportunity"
    description: "Collect Opportunity details and create the record"

    reasoning:
        instructions: ->
            # Step 1: Collect required fields if missing
            if @variables.opp_name == "":
                | I need the following information to create an Opportunity:
                | 1. Opportunity Name
                | 2. Close Date (YYYY-MM-DD format)
                | 3. Stage (e.g., Prospecting, Qualification, Closed Won)
                | 4. Account ID (18-character Salesforce ID)
                |
                | Please provide the Opportunity Name first.

            if @variables.opp_name != "" and @variables.close_date == "":
                | Please provide the Close Date in YYYY-MM-DD format.

            if @variables.opp_name != "" and @variables.close_date != "" and @variables.stage_name == "":
                | Please provide the Stage (e.g., Prospecting, Qualification, Closed Won).

            if @variables.opp_name != "" and @variables.close_date != "" and @variables.stage_name != "" and @variables.account_id == "":
                | Please provide the Account ID (18-character Salesforce ID).

            # Step 2: When all fields collected and not yet created, create it automatically
            if @variables.opp_name != "" and @variables.close_date != "" and @variables.stage_name != "" and @variables.account_id != "" and @variables.created_oppty_id == "":
                run @actions.Create_Opportunity_Simple
                    with oppName=@variables.opp_name
                    with closeDate=@variables.close_date
                    with stageName=@variables.stage_name
                    with accountId=@variables.account_id
                    set @variables.created_oppty_id = @outputs.recordId

            # Step 3: Confirm success
            if @variables.created_oppty_id != "":
                | Opportunity created successfully! ID: {!@variables.created_oppty_id}
                | View it at: /lightning/r/Opportunity/{!@variables.created_oppty_id}/view

        actions:
            capture_fields: @utils.setVariables
                description: "Capture Opportunity field values from user input"
                with opp_name=...
                with close_date=...
                with stage_name=...
                with account_id=...

    actions:
        Create_Opportunity_Simple:
            description: "Creates an Opportunity record with individual field parameters"
            label: "Create Opportunity Simple"
            target: "apex://CreateOpportunitySimpleAction"

            inputs:
                "oppName": string
                    description: "Opportunity Name"
                    label: "Name"
                "closeDate": string
                    description: "Close Date (YYYY-MM-DD)"
                    label: "Close Date"
                "stageName": string
                    description: "Stage Name"
                    label: "Stage"
                "accountId": string
                    description: "Account ID"
                    label: "Account ID"

            outputs:
                "recordId": string
                    description: "Created record ID"
                    label: "Record ID"
                "errorMessage": string
                    description: "Error message if failed"
                    label: "Error Message"
                "isSuccess": boolean
                    description: "Success flag"
                    label: "Success"
