system:
    instructions: "You are an AI Agent that helps users create Opportunities in Salesforce."
    messages:
        welcome: |
            Hi! I can help you create Opportunities. What would you like to do?
        error: "Sorry, something went wrong. Please try again."

config:
    developer_name: "Manage_Opportunities"
    agent_label: "Manage Opportunities"
    description: "Agent for Opportunity creation with guided field collection"
    default_agent_user: "manage_opportunities@00drk00000tnbfy1145514368.ext"

language:
    default_locale: "en_US"

variables:
    opportunity_id: mutable string = ""
        description: "ID of created Opportunity"
    last_error: mutable string = ""
        description: "Last error message from create action"

start_agent router:
    label: "Opportunity Router"
    description: "Route user requests to create opportunities"
    reasoning:
        instructions: ->
            | If the user wants to create an Opportunity, use {!@actions.go_to_create}.
        actions:
            go_to_create: @utils.transition to @subagent.create_opportunity
                description: "User wants to create a new Opportunity"

subagent create_opportunity:
    label: "Create Opportunity"
    description: "Guide user through creating an Opportunity"

    reasoning:
        instructions: ->
            | You create Opportunities in Salesforce.
            |
            | if {!@variables.opportunity_id} != "":
            |     Say: "Opportunity created! View it: /lightning/r/Opportunity/{!@variables.opportunity_id}/view"
            |     Stop.
            |
            | if {!@variables.last_error} != "":
            |     Say: "Error creating Opportunity: {!@variables.last_error}"
            |     Ask if they want to try again with different values.
            |     Stop.
            |
            | Required fields to create an Opportunity:
            | - Name (any text)
            | - CloseDate (YYYY-MM-DD format)
            | - StageName (valid Salesforce stage like Prospecting, Qualification, Closed Won)
            | - AccountId (18-character Salesforce ID starting with 001)
            |
            | If the user has provided ALL FOUR required fields in their message:
            |     Extract the values and use {!@actions.create_opp} with those values in JSON format.
            |
            | If any required field is missing:
            |     List the required fields and ask the user to provide the missing information.

        actions:
            create_opp: @actions.create_opportunity
                description: "Create Opportunity with user-provided field values in JSON format"
                inputs:
                    fieldValuesJson: string
                set @variables.opportunity_id = @outputs.recordId
                set @variables.last_error = @outputs.errorMessage

    actions:
        create_opportunity:
            description: "Create Opportunity record"
            label: "Create Opportunity"
            require_user_confirmation: False
            include_in_progress_indicator: True
            progress_indicator_message: "Creating Opportunity..."
            target: "apex://d26__CreateCustomObjectAction"

            inputs:
                "configurationName": string
                    description: "Configuration name"
                    label: "Configuration Name"
                    is_required: False
                    is_user_input: False
                "fieldValuesJson": string
                    description: "JSON with field values: Name, CloseDate, StageName, AccountId"
                    label: "Field Values JSON"
                    is_required: False
                    is_user_input: True

            outputs:
                "errorMessage": string
                    description: "Error message if failed"
                    label: "Error Message"
                "isSuccess": boolean
                    description: "Success flag"
                    label: "Success"
                "recordId": string
                    description: "Created record ID"
                    label: "Record ID"
